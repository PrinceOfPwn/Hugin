---
import ravenMark from "../../hugin/assets/raven-mark.png";
import favicon from "../../hugin/assets/favicon.png";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, image = "/Hugin/og.png", jsonLd } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === "HUGIN" ? title : `${title} · HUGIN`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#08070c" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <script is:inline type="module">
      window.loadHuginPagefind = () => import("/Hugin/pagefind/pagefind.js");
    </script>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="/Hugin/" aria-label="HUGIN home">
        <img src={ravenMark.src} alt="" width="46" height="46" />
        <span><strong>HUGIN</strong><small>Knowledge Universe</small></span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="/Hugin/explore/">Explore</a>
        <a href="/Hugin/graph/">Universe</a>
        <a href="/Hugin/dataset/">Dataset</a>
        <a href="/Hugin/quality/">Quality</a>
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>HUGIN is a static, owner-authorized research dataset. Generated relationships are always labeled.</p>
      <a href="https://github.com/PrinceOfPwn/Hugin">View source on GitHub</a>
    </footer>
  </body>
</html>
