---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { manifest, quality } from "../../lib/data";

const quarantineReasons = Object.entries(
  quality.quarantinedNodes.reduce(
    (counts, item) => ({ ...counts, [item.reason]: (counts[item.reason] || 0) + 1 }),
    {} as Record<string, number>
  )
).sort((a, b) => b[1] - a[1]);
const relationReasons = Object.entries(
  quality.quarantinedRelations.reduce(
    (counts, item) => ({ ...counts, [item.reason]: (counts[item.reason] || 0) + 1 }),
    {} as Record<string, number>
  )
).sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="Data Quality"
  description="Build-enforced content quality, anonymization, and quarantine reporting for HUGIN."
>
  <header class="wrap page-head">
    <p class="eyebrow">Build-enforced quality</p>
    <h1>Only useful knowledge enters the public graph.</h1>
    <p class="lede">
      Raw imports are classified before publication. Administrative slides, generic objectives,
      private paths, provider names, and unsupported relations fail closed.
    </p>
  </header>

  <dl class="metric-strip wrap" aria-label="Quality metrics">
    <div class="metric"><dt>Raw records audited</dt><dd>{manifest.counts.rawRecords.toLocaleString()}</dd></div>
    <div class="metric"><dt>Knowledge nodes</dt><dd>{manifest.counts.coreEntities.toLocaleString()}</dd></div>
    <div class="metric"><dt>Evidence quarantined</dt><dd>{manifest.counts.quarantinedEvidence.toLocaleString()}</dd></div>
    <div class="metric"><dt>Private identifiers allowed</dt><dd>0</dd></div>
  </dl>

  <section class="wrap quality-grid">
    <article>
      <p class="eyebrow">Evidence quarantine</p>
      <h2>Rejected before indexing</h2>
      <table class="quality-table">
        <thead><tr><th>Reason</th><th>Records</th></tr></thead>
        <tbody>
          {quarantineReasons.map(([reason, count]) => (
            <tr><td>{reason.replace(/-/g, " ")}</td><td>{count.toLocaleString()}</td></tr>
          ))}
        </tbody>
      </table>

      <p class="eyebrow" style="margin-top:40px">Relation quarantine</p>
      <h2>Edges removed from the graph</h2>
      <table class="quality-table">
        <thead><tr><th>Reason</th><th>Relations</th></tr></thead>
        <tbody>
          {relationReasons.map(([reason, count]) => (
            <tr><td>{reason.replace(/-/g, " ")}</td><td>{count.toLocaleString()}</td></tr>
          ))}
        </tbody>
      </table>
    </article>

    <aside>
      <section class="sidebar-section">
        <p class="eyebrow">Publication states</p>
        <table class="quality-table">
          <tbody>
            <tr><td>Core knowledge</td><td>{quality.states.core.toLocaleString()}</td></tr>
            <tr><td>Optional sources</td><td>{quality.states.support.toLocaleString()}</td></tr>
            <tr><td>Anonymous evidence</td><td>{quality.states.evidence.toLocaleString()}</td></tr>
            <tr><td>Quarantined</td><td>{quality.states.quarantined.toLocaleString()}</td></tr>
          </tbody>
        </table>
      </section>
      <section class="sidebar-section">
        <p class="eyebrow">Build gate</p>
        <h2>Automatic rejection</h2>
        <p>
          The deployment stops if public artifacts contain named providers, course IDs,
          local usernames, private paths, raw evidence pages, duplicate IDs, broken
          relations, or unlabeled generated similarity.
        </p>
      </section>
      <section class="sidebar-section">
        <p class="eyebrow">Evidence policy</p>
        <h2>Context, not clutter</h2>
        <p>
          Anonymous evidence can support a record inside its detail page. It cannot
          become an independent catalog result or a graph node.
        </p>
      </section>
    </aside>
  </section>
</BaseLayout>
