---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { entities, manifest } from "../../lib/data";
const isolated = entities.filter((entity) => entity.degree === 0).length;
const byKind = Object.entries(entities.reduce((counts, entity) => ({ ...counts, [entity.kind]: (counts[entity.kind] || 0) + 1 }), {} as Record<string, number>)).sort((a, b) => b[1] - a[1]);
---
<BaseLayout title="Data Quality" description="Integrity, quarantine and coverage report for the HUGIN dataset.">
  <header class="wrap section"><p class="eyebrow">Build-enforced quality</p><h1>Every omission becomes visible.</h1><p class="lede">The manifest must preserve exactly 5,608 entities. Invalid relations are quarantined, generated links are labeled, routes are sanitized and every node remains reachable through catalog, search and galaxy membership.</p></header>
  <section class="wrap" style="padding-bottom:70px"><div class="metrics"><div class="metric"><strong>{manifest.counts.nodes.toLocaleString()}</strong><span>validated IDs and routes</span></div><div class="metric"><strong>{manifest.counts.quarantinedRelations}</strong><span>invalid self-relations quarantined</span></div><div class="metric"><strong>{isolated.toLocaleString()}</strong><span>without original relations; still visible</span></div><div class="metric"><strong>0</strong><span>absolute local paths allowed</span></div></div><div class="grid" style="margin-top:30px">{byKind.map(([kind, count]) => <div class="card"><span class="badge">{kind}</span><h3 style="margin:16px 0 0">{count.toLocaleString()}</h3></div>)}</div></section>
</BaseLayout>
