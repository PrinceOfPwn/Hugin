---
import EntityPage from "../../components/EntityPage.astro";
import { entities } from "../../lib/data";
const routed = new Set(["technique", "playbook", "concept", "detection", "chain", "atlas_reference"]);
export function getStaticPaths() { return entities.filter((entity) => !routed.has(entity.kind)).map((entity) => ({ params: { slug: entity.slug }, props: { entity } })); }
const { entity } = Astro.props;
---
<EntityPage entity={entity} />
