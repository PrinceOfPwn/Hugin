---
import EntityPage from "../../components/EntityPage.astro";
import { entities } from "../../lib/data";
export function getStaticPaths() { return entities.filter((entity) => ["technique", "playbook"].includes(entity.kind)).map((entity) => ({ params: { slug: entity.slug }, props: { entity } })); }
const { entity } = Astro.props;
---
<EntityPage entity={entity} />
