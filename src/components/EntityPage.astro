---
import { marked } from "marked";
import sanitizeHtml from "sanitize-html";
import BaseLayout from "../layouts/BaseLayout.astro";
import { bodyFor, curatedRelations, entityById } from "../lib/data";
import type { Entity } from "../lib/types";

const { entity } = Astro.props as { entity: Entity };
const body = bodyFor(entity);
const html = sanitizeHtml(await marked.parse(body), {
  allowedTags: sanitizeHtml.defaults.allowedTags.concat(["img"]),
  allowedAttributes: { a: ["href", "title"], img: ["src", "alt", "title", "loading"] },
  allowedSchemes: ["https", "http", "mailto"]
});
const relations = curatedRelations.filter((edge) => edge.source === entity.id || edge.target === entity.id);
const neighbors = relations.slice(0, 40).map((edge) => ({ edge, entity: entityById.get(edge.source === entity.id ? edge.target : edge.source) })).filter((item) => item.entity);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: entity.title,
  description: entity.summary,
  keywords: entity.tags,
  isPartOf: { "@type": "Dataset", name: "HUGIN Knowledge Universe" }
};
---

<BaseLayout title={entity.title} description={entity.summary} jsonLd={jsonLd}>
  <header class="entity-head">
    <div class="wrap">
      <p class="eyebrow">{entity.galaxyId} / {entity.kind}</p>
      <h1>{entity.title}</h1>
      <p class="lede">{entity.summary}</p>
      <div class="meta-row"><span class="badge">{entity.category}</span>{entity.tier && <span class="badge">Tier {entity.tier}</span>}{entity.mitre.map((value) => <span class="badge">{value}</span>)}</div>
    </div>
  </header>
  <div class="wrap entity-grid">
    <article class="prose" data-pagefind-body set:html={html} />
    <aside class="sidebar">
      <div class="card">
        <p class="eyebrow">Provenance</p>
        {entity.provenance.map((source) => <p><strong>{source.sourceLabel}</strong><br /><small>{source.sourceHash}</small></p>)}
        <p><a href={`https://github.com/PrinceOfPwn/Hugin/tree/main/data/source/public-graph.json`}>Permanent source on GitHub</a></p>
      </div>
      <div class="card" style="margin-top: 14px">
        <p class="eyebrow">Original relations · {relations.length}</p>
        {neighbors.length ? <ul>{neighbors.map(({ edge, entity: target }) => <li><a href={`/Hugin${target!.route}`}>{target!.title}</a> <small>({edge.type})</small></li>)}</ul> : <p>This entity has no original relation. It remains visible through its galaxy and generated semantic neighborhood.</p>}
        <a href={`/Hugin/graph/?focus=${encodeURIComponent(entity.id)}&edges=curated,similarity&k=3`}>Open contextual graph →</a>
      </div>
    </aside>
  </div>
</BaseLayout>
